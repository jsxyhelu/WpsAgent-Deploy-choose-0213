# WpsAgent 配置文件

# ========================================
# 模型配置
# ========================================

# 模型类型：cloud（云端模型）或 local（本地模型）
MODEL_TYPE=cloud

# ========================================
# 云端模型配置（MODEL_TYPE=cloud 时使用）
# ========================================
# API 端点地址（支持 OpenAI 兼容接口）
API_URL=https://api.deepseek.com/chat/completions
# API 密钥
API_KEY=sk-db6aab7933a2427497761018834fe5b1
# 模型名称
API_MODEL=deepseek-chat

# ========================================
# 本地模型配置（MODEL_TYPE=local 时使用）
# ========================================
# 本地模型服务地址（例如 Ollama、vLLM、LocalAI 等）
LOCAL_API_URL=http://localhost:11434/api/chat
# 本地模型名称（例如：llama2、qwen、chatglm 等）
LOCAL_MODEL_NAME=llama2
# 本地模型是否需要认证（true/false）
LOCAL_API_NEED_AUTH=false
# 本地 API 密钥（如果需要）
LOCAL_API_KEY=

# ========================================
# 预设模型配置（快速切换）
# ========================================

# DeepSeek（云端）
# MODEL_TYPE=cloud
# API_URL=https://api.deepseek.com/chat/completions
# API_MODEL=deepseek-chat

# OpenAI（云端）
# MODEL_TYPE=cloud
# API_URL=https://api.openai.com/v1/chat/completions
# API_MODEL=gpt-3.5-turbo

# Ollama（本地）
# MODEL_TYPE=local
# LOCAL_API_URL=http://localhost:11434/api/chat
# LOCAL_MODEL_NAME=llama2

# vLLM（本地）
# MODEL_TYPE=local
# LOCAL_API_URL=http://localhost:8000/v1/chat/completions
# LOCAL_MODEL_NAME=meta-llama/Llama-2-7b-chat-hf

# LocalAI（本地）
# MODEL_TYPE=local
# LOCAL_API_URL=http://localhost:8080/v1/chat/completions
# LOCAL_MODEL_NAME=gpt-3.5-turbo

# ========================================
# 排版配置（单位：厘米）
# ========================================
MARGIN_TOP=2.54
MARGIN_BOTTOM=2.54
MARGIN_LEFT=3.18
MARGIN_RIGHT=3.18

# 行距设置（磅）
LINE_SPACING=28

# 字体配置
TITLE_FONT=黑体
TITLE_FONT_SIZE=16
H1_FONT=黑体
H1_FONT_SIZE=16
H2_FONT=黑体
H2_FONT_SIZE=14
H3_FONT=楷体
H3_FONT_SIZE=12
BRACKET_FONT=仿宋
BRACKET_FONT_SIZE=12

# ========================================
# 服务器配置
# ========================================
PORT=3889
HOST=0.0.0.0
